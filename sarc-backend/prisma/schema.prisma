generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  STUDENT
  FACULTY
  INDUSTRY
  ADMIN
}

enum ProjectStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

model User {
  id           Int     @id @default(autoincrement())
  fullName     String
  email        String  @unique
  password     String
  role         Role    @default(STUDENT)
  profilePhoto String?

  failedLoginAttempts Int       @default(0)
  lockoutUntil        DateTime?
  refreshToken        String?

  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  studentProfile  StudentProfile?
  facultyProfile  FacultyProfile?
  industryProfile IndustryProfile?
  adminProfile    AdminProfile?

  notifications Notification[] @relation("UserNotifications")

  guideTeamsLed         GuideTeam[]            @relation("GuideTeamLeader")
  guideTeamsAssigned    GuideTeam[]            @relation("GuideAssigned")
  guideTeamMemberships  GuideTeamMember[]
  facultyGuideSlot      FacultyGuideSlot?
  facultyTeamSelections FacultyTeamSelection[]

  isFirstLogin      Boolean   @default(true)
  accountStatus     String    @default("PENDING")
  passwordChangedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StudentProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  studentId            String?
  batch                String?
  department           String?
  yearOfStudy          String?
  section              String?
  bio                  String?
  skills               String[]
  programmingLanguages String[]
  projectsCompleted    Int?
  githubLink           String?
  resumeFile           String?
  areasOfInterest      String[]

  applications Application[] @relation("StudentApplications")
  teamsLed     Team[]        @relation("TeamLeader")
  memberships  TeamMember[]  @relation("TeamMemberships")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FacultyProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  employeeId        String?
  department        String?
  designation       String?
  researchAreas     String[]
  yearsOfExperience Int?
  skills            String[]
  contactNumber     String?
  linkedin          String?
  bio               String?

  projects     Project[]     @relation("FacultyProjects")
  projectIdeas ProjectIdea[] @relation("FacultyProjectIdeas")
  pastProjects String[]      @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model IndustryProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  companyName String?
  designation String?
  bio         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminProfile {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  department String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Project {
  id               Int           @id @default(autoincrement())
  title            String
  domain           String?
  problemStatement String?
  description      String
  technologies     String[]
  expectedOutcome  String?
  skillsRequired   String[]
  numberOfStudents Int?
  status           ProjectStatus @default(OPEN)
  deadline         DateTime?

  proposalFile      String?
  documentationFile String?
  demoFile          String?
  imageFiles        String[]

  facultyId Int
  faculty   FacultyProfile @relation("FacultyProjects", fields: [facultyId], references: [id], onDelete: Cascade)

  applications Application[]
  teams        Team[]
  milestones   Milestone[]   @relation("ProjectMilestones")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facultyId])
}

model ProjectIdea {
  id                    Int      @id @default(autoincrement())
  title                 String
  description           String
  suggestedTechnologies String[]
  difficultyLevel       String? // Beginner, Intermediate, Advanced
  skillsRequired        String[]
  numberOfStudents      Int?
  supportingFile        String?

  facultyId Int
  faculty   FacultyProfile @relation("FacultyProjectIdeas", fields: [facultyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([facultyId])
}

model Application {
  id         Int     @id @default(autoincrement())
  studentId  Int
  projectId  Int
  status     String  @default("PENDING") // PENDING, SHORTLISTED, ACCEPTED, REJECTED
  message    String?
  resumeFile String?

  student StudentProfile @relation("StudentApplications", fields: [studentId], references: [id], onDelete: Cascade)
  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([projectId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  title     String? // Optional title for the notification
  type      String // e.g., APPLICATION_SUBMITTED, APPLICATION_STATUS_CHANGED
  message   String
  read      Boolean  @default(false)
  link      String? // Optional routing link
  createdAt DateTime @default(now())

  @@index([userId])
}

model Team {
  id          Int      @id @default(autoincrement())
  name        String
  description String?
  projectId   Int?
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  status      String   @default("FORMING") // FORMING, READY, ASSIGNED

  leaderId Int
  leader   StudentProfile @relation("TeamLeader", fields: [leaderId], references: [id])

  members TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([leaderId])
}

model TeamMember {
  id        Int            @id @default(autoincrement())
  teamId    Int
  team      Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  studentId Int
  student   StudentProfile @relation("TeamMemberships", fields: [studentId], references: [id], onDelete: Cascade)
  role      String?

  joinedAt DateTime @default(now())

  @@unique([teamId, studentId])
}

model Milestone {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  status      String   @default("PENDING") // PENDING, SUBMITTED, COMPLETED
  projectId   Int
  project     Project  @relation("ProjectMilestones", fields: [projectId], references: [id], onDelete: Cascade)

  submissionNotes String?
  submissionFile  String?
  submittedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GuideSelectionStatus {
  PENDING
  FACULTY_SELECTED
  ACCEPTED
  STUDENT_SELECTED
  FINALIZED
}

enum GuideSelectionPhase {
  CLOSED
  FACULTY_SELECTION
  STUDENT_SELECTION
  COMPLETED
}

model GuideTeam {
  id                String                 @id @default(uuid())
  teamId            String                 @unique // e.g. "TEAM-2024-A3F9"
  teamName          String
  projectTitle      String
  description       String
  domain            String
  leaderId          Int
  leader            User                   @relation("GuideTeamLeader", fields: [leaderId], references: [id])
  members           GuideTeamMember[]
  guideId           Int?
  guide             User?                  @relation("GuideAssigned", fields: [guideId], references: [id])
  guideStatus       GuideSelectionStatus   @default(PENDING)
  isFinalized       Boolean                @default(false)
  abstractFile      String?
  createdAt         DateTime               @default(now())
  facultySelections FacultyTeamSelection[]
}

model GuideTeamMember {
  id           String       @id @default(uuid())
  teamId       String
  team         GuideTeam    @relation(fields: [teamId], references: [id])
  studentId    Int
  student      User         @relation(fields: [studentId], references: [id])
  isLeader     Boolean      @default(false)
  inviteStatus InviteStatus @default(PENDING)
  invitedAt    DateTime     @default(now())
  respondedAt  DateTime?

  @@unique([teamId, studentId])
}

model FacultyGuideSlot {
  id         String @id @default(uuid())
  facultyId  Int    @unique
  faculty    User   @relation(fields: [facultyId], references: [id])
  totalSlots Int    @default(7)
  usedSlots  Int    @default(0)
}

model FacultyTeamSelection {
  id          String       @id @default(uuid())
  facultyId   Int
  faculty     User         @relation(fields: [facultyId], references: [id])
  teamId      String
  team        GuideTeam    @relation(fields: [teamId], references: [id])
  status      InviteStatus @default(PENDING)
  selectedAt  DateTime     @default(now())
  respondedAt DateTime?

  @@unique([facultyId, teamId])
}

model GuideSelectionConfig {
  id    String              @id @default("singleton")
  phase GuideSelectionPhase @default(CLOSED)
}

model GlobalMilestone {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  dueDate     DateTime
  status      String   @default("PENDING") // PENDING, COMPLETED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
